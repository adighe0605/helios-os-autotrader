# =========================================
# AI Trader — environment variables
# Copy to .env and fill in. Never commit .env.
# =========================================

# ---- Core ----
TRADING_MODE=paper          # paper | live  (default paper)
ENVIRONMENT=development     # development | staging | production
LOG_LEVEL=INFO
SECRET_KEY=change-me-please-32-bytes-min

# ---- Database / Redis ----
DATABASE_URL=postgresql+psycopg://aitrader:aitrader@db:5432/aitrader
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Auth ----
JWT_SECRET=change-me-different-from-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3001

# ---- Anthropic (AI agents) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# ---- Alpaca broker ----
# Paper:  https://paper-api.alpaca.markets
# Live:   https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_DATA_URL=https://data.alpaca.markets

# ---- Market data providers (optional) ----
POLYGON_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ---- Risk defaults ----
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_MAX_POSITION_PCT=10.0
RISK_MAX_DRAWDOWN_PCT=15.0
RISK_MAX_TRADES_PER_DAY=25
RISK_COOLDOWN_AFTER_LOSS_MIN=15

# ---- Autonomous trading ----
# Set AUTONOMOUS_MODE=true to let the bot scan + execute without human approval.
# Always run in paper mode first to validate behavior before enabling live.
AUTONOMOUS_MODE=false
AUTO_MIN_CONFIDENCE=0.70        # 0.0–1.0: AI confidence threshold to auto-execute
AUTO_MAX_POSITION_PCT=3.0       # max % of equity per single auto-trade
AUTO_SCAN_INTERVAL_SEC=60       # how often the scan-decide-execute cycle fires (seconds)
AUTO_MAX_CONCURRENT_POSITIONS=5 # max number of open auto-managed positions at once

# ---- Penny stock filters ----
PENNY_MAX_PRICE=5.00            # only consider stocks at or below this price
PENNY_MIN_PRICE=0.10            # skip sub-penny traps
PENNY_MIN_VOLUME=300000         # minimum daily volume
PENNY_MIN_VOLUME_SURGE=1.5      # current vol must be ≥ X × 20-day average vol
PENNY_MAX_SPREAD_PCT=3.0        # skip if estimated bid-ask spread > 3%

# ---- Notifications (optional) ----
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_DEFAULT_MODE=paper
